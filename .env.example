# ===========================================
# VARIÁVEIS DE AMBIENTE - UTI DIGITAL
# ===========================================
# Copie este arquivo para .env e preencha com seus dados

# String de conexão com o banco PostgreSQL
# Formato local: postgres://usuario:senha@localhost:5432/nome_banco
# Formato online: postgres://usuario:senha@host:5432/database?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/utidigital

# Chave secreta para sessões (pode ser qualquer texto longo)
SESSION_SECRET=utidigital_secret_key_123456789

# ===========================================
# EXEMPLO PARA PostgreSQL LOCAL
# ===========================================
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/utidigital
# SESSION_SECRET=minha_chave_secreta

# ===========================================
# EXEMPLO PARA NEON (Online)
# ===========================================
# DATABASE_URL=postgres://usuario:senha@ep-xxx.us-east-1.aws.neon.tech/utidigital?sslmode=require
# SESSION_SECRET=qualquer_texto

# ===========================================
# EXEMPLO PARA SUPABASE (Online)
# ===========================================
# DATABASE_URL=postgres://postgres:[YOUR-PASSWORD]@db.xxx.supabase.co:5432/postgres
# SESSION_SECRET=qualquer_texto